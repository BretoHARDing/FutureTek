<!-- ============================================================
     FUTURETECH — TESTIMONIALS / SOCIAL PROOF SECTION
     AU customer reviews with verified purchase badges
============================================================ -->

<section class="ft-testimonials section-pad">
  <div class="ft-container">
    <div class="ft-section-head">
      <span class="ft-label">{{ section.settings.label | default: 'Customer Reviews' }}</span>
      <h2 class="ft-section-title">{{ section.settings.heading | default: 'Loved by Aussie Tech Enthusiasts' }}</h2>
      <div class="ft-rating-hero">
        <span class="ft-big-stars">★★★★★</span>
        <span class="ft-rating-text">{{ section.settings.rating_text | default: '4.9/5 from 3,200+ verified Australian reviews' }}</span>
      </div>
    </div>

    <div class="ft-testi__grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="ft-testi__card" {{ block.shopify_attributes }}>
            <div class="ft-testi__stars">
              {% assign rating = block.settings.rating | default: 5 | plus: 0 %}
              {% for i in (1..5) %}
                {% if i <= rating %}★{% else %}☆{% endif %}
              {% endfor %}
            </div>
            <p class="ft-testi__quote">"{{ block.settings.review_text }}"</p>
            <div class="ft-testi__author">
              <div class="ft-testi__av">{{ block.settings.name | slice: 0 }}</div>
              <div>
                <div class="ft-testi__name">{{ block.settings.name }}</div>
                <div class="ft-testi__product">{{ block.settings.product }}</div>
                <div class="ft-testi__location">{{ block.settings.location }}</div>
              </div>
            </div>
            <div class="ft-testi__verified">✅ Verified AU Purchase · {{ block.settings.delivery_note }}</div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"My dog absolutely loves the GPS tracker. I can see exactly where she is at all times and the battery lasts 5 days. Worth every dollar — ripper product!"</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">S</div>
            <div>
              <div class="ft-testi__name">Sarah M.</div>
              <div class="ft-testi__product">PetSafe GPS Tracker Pro</div>
              <div class="ft-testi__location">🇦🇺 Brisbane, QLD</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered in 6 days</div>
        </div>
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"The smartwatch tracks everything — sleep, heart rate, workouts. Synced perfectly with my iPhone and honestly looks more expensive than it is."</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">J</div>
            <div>
              <div class="ft-testi__name">James R.</div>
              <div class="ft-testi__product">FitPro X8 Health Smartwatch</div>
              <div class="ft-testi__location">🇦🇺 Melbourne, VIC</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered in 4 days</div>
        </div>
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"Delivery was next day, packaging was excellent and the noise-cancelling headphones are genuinely the best I've owned. Futuristech is my new go-to."</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">P</div>
            <div>
              <div class="ft-testi__name">Priya K.</div>
              <div class="ft-testi__product">ProSound ANC Headphones</div>
              <div class="ft-testi__location">🇦🇺 Sydney, NSW</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered next day</div>
        </div>
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"Sleep tracker completely changed my routine. I finally understand my sleep patterns and wake up feeling so much better. Legit game changer."</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">T</div>
            <div>
              <div class="ft-testi__name">Tom B.</div>
              <div class="ft-testi__product">SleepSense Smart Monitor</div>
              <div class="ft-testi__location">🇦🇺 Perth, WA</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered in 7 days</div>
        </div>
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"Futuristech's support team helped me set up my smart home hub in under 20 minutes over chat. Ripper service from start to finish — couldn't be happier."</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">E</div>
            <div>
              <div class="ft-testi__name">Emma L.</div>
              <div class="ft-testi__product">SmartHub Connect</div>
              <div class="ft-testi__location">🇦🇺 Adelaide, SA</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered in 3 days</div>
        </div>
        <div class="ft-testi__card">
          <div class="ft-testi__stars">★★★★★</div>
          <p class="ft-testi__quote">"Auto pet feeder is an absolute game changer. I schedule meals from my phone and the camera lets me check on my cat anytime. My cat loves it too."</p>
          <div class="ft-testi__author">
            <div class="ft-testi__av">D</div>
            <div>
              <div class="ft-testi__name">Daniel W.</div>
              <div class="ft-testi__product">PetFeeder Smart Auto</div>
              <div class="ft-testi__location">🇦🇺 Hobart, TAS</div>
            </div>
          </div>
          <div class="ft-testi__verified">✅ Verified AU Purchase · Delivered in 8 days</div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Futuristech Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by Aussie Tech Enthusiasts"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Summary Text",
      "default": "4.9/5 from 3,200+ verified Australian reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product Name",
          "default": "Futuristech Product"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "🇦🇺 Brisbane, QLD"
        },
        {
          "type": "text",
          "id": "delivery_note",
          "label": "Delivery Note",
          "default": "Delivered in 5 days"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Futuristech Testimonials"
    }
  ]
}
{% endschema %}

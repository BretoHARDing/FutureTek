<script>
function ftUECalc() {
  const sell = parseFloat(document.getElementById('ft-ue-sell').value) || 0;
  const cost = parseFloat(document.getElementById('ft-ue-cost').value) || 0;
  const ship = parseFloat(document.getElementById('ft-ue-ship').value) || 0;
  const ad = parseFloat(document.getElementById('ft-ue-ad').value) || 0;
  const feesInput = parseFloat(document.getElementById('ft-ue-fees').value);
  const returnsPct = parseFloat(document.getElementById('ft-ue-returns-pct').value) || 0;

  const fees = isNaN(feesInput) ? (sell * 0.029 + 0.30) : feesInput;
  const returnsAllowance = sell * (returnsPct / 100);
  const totalCost = cost + ship + ad + fees + returnsAllowance;
  const netProfit = sell - totalCost;
  const netMarginPct = sell > 0 ? (netProfit / sell * 100).toFixed(1) : 0;

  const rows = document.getElementById('ft-ue-rows');
  rows.innerHTML = [
    { label: 'Sell Price', val: '$' + sell.toFixed(2), cls: '' },
    { label: '− Supplier Cost', val: '-$' + cost.toFixed(2), cls: 'red' },
    { label: '− Shipping', val: '-$' + ship.toFixed(2), cls: 'red' },
    { label: '− Ad Spend (CAC)', val: '-$' + ad.toFixed(2), cls: 'red' },
    { label: '− Payment Fees', val: '-$' + fees.toFixed(2), cls: 'red' },
    { label: '− Returns Allowance', val: '-$' + returnsAllowance.toFixed(2), cls: 'red' },
  ].map(r => `<div class="ft-ue-calc__row"><span class="ft-ue-calc__row-label">${r.label}</span><span class="ft-ue-calc__row-val${r.cls ? ' ft-ue-calc__row-val--' + r.cls : ''}">${r.val}</span></div>`).join('');

  let cls = 'good', health = '✓ Healthy margin — profitable unit economics';
  if (netProfit < 0) { cls = 'bad'; health = '✗ Negative margin — review costs immediately'; }
  else if (netMarginPct < 20) { cls = 'warn'; health = '⚠ Low margin — consider reducing CAC or raising price'; }

  document.getElementById('ft-ue-bottom').innerHTML = `
    <div class="ft-ue-calc__profit ft-ue-calc__profit--${cls}">
      <span class="ft-ue-calc__profit-label">Net Profit / Order</span>
      <span class="ft-ue-calc__profit-val">${netProfit >= 0 ? '+' : ''}$${netProfit.toFixed(2)} (${netMarginPct}%)</span>
    </div>
    <div class="ft-ue-calc__health">${health}</div>
  `;
}
document.addEventListener('DOMContentLoaded', ftUECalc);
</script>


    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Track the metrics that matter: CAC, MER, gross margin, chargeback rate and autonomy score." },
    { "type": "text", "id": "gross_margin", "label": "Gross Margin %", "default": "58" },
    { "type": "text", "id": "cac", "label": "CAC (AUD)", "default": "24" },
    { "type": "text", "id": "mer", "label": "MER (x)", "default": "3.2" },
    { "type": "text", "id": "refund_rate", "label": "Refund Rate %", "default": "3.2" },

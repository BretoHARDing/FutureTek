<!-- ============================================================
     FUTURETECH — CATEGORIES SECTION
     4-category asymmetric grid: Electronics, Fitness, Pet Tech, Wellbeing
============================================================ -->

<section class="ft-categories section-pad" id="categories">
  <div class="ft-container">
    <div class="ft-section-head">
      <span class="ft-label">{{ section.settings.section_tag | default: 'Shop by Category' }}</span>
      <h2 class="ft-section-title">{{ section.settings.heading | default: 'Everything Tech, All in One Place' }}</h2>
      <p class="ft-section-sub">{{ section.settings.subheading | default: 'Four powerful categories. Thousands of products. One store built for the tech-forward Aussie lifestyle.' }}</p>
    </div>

    <div class="ft-cat-grid">

      <!-- Electronics — wide tall card -->
      <a href="{{ section.settings.electronics_url | default: '/collections/electronics' }}" class="ft-cat-card ft-cat--electronics ft-cat--wide">
        <div class="ft-cat__glow"></div>
        <span class="ft-cat__emoji">{{ section.settings.electronics_emoji | default: '💻' }}</span>
        <span class="ft-cat__badge">{{ section.settings.electronics_badge | default: 'Most Popular' }}</span>
        <div class="ft-cat__name">{{ section.settings.electronics_title | default: 'Consumer Electronics' }}</div>
        <div class="ft-cat__desc">{{ section.settings.electronics_desc | default: 'The latest smartphones, wireless audio, computing accessories, smart displays and home automation devices.' }}</div>
        <div class="ft-cat__chips">
          <span>📱 Smartphones</span>
          <span>🎧 Wireless Audio</span>
          <span>💾 Accessories</span>
          <span>🖥️ Computing</span>
          <span>🏠 Smart Home</span>
        </div>
        <div class="ft-cat__count">{{ section.settings.electronics_count | default: '500+ Products' }}</div>
        <div class="ft-cat__link">
          Shop Electronics
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Fitness -->
      <a href="{{ section.settings.fitness_url | default: '/collections/fitness-tech' }}" class="ft-cat-card ft-cat--fitness">
        <div class="ft-cat__glow"></div>
        <span class="ft-cat__emoji">{{ section.settings.fitness_emoji | default: '💪' }}</span>
        <span class="ft-cat__badge">{{ section.settings.fitness_badge | default: 'Top Rated' }}</span>
        <div class="ft-cat__name">{{ section.settings.fitness_title | default: 'Fitness Technology' }}</div>
        <div class="ft-cat__desc">{{ section.settings.fitness_desc | default: 'Smarter workouts with wearables, fitness trackers and performance monitors.' }}</div>
        <div class="ft-cat__chips">
          <span>⌚ Smartwatches</span>
          <span>🏃 Trackers</span>
        </div>
        <div class="ft-cat__count">{{ section.settings.fitness_count | default: '320+ Products' }}</div>
        <div class="ft-cat__link">
          Shop Fitness
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Pet Tech -->
      <a href="{{ section.settings.pettech_url | default: '/collections/pet-technology' }}" class="ft-cat-card ft-cat--pettech">
        <div class="ft-cat__glow"></div>
        <span class="ft-cat__emoji">{{ section.settings.pettech_emoji | default: '🐾' }}</span>
        <span class="ft-cat__badge">{{ section.settings.pettech_badge | default: 'New Arrivals' }}</span>
        <div class="ft-cat__name">{{ section.settings.pettech_title | default: 'Pet Technology' }}</div>
        <div class="ft-cat__desc">{{ section.settings.pettech_desc | default: 'Keep your pets safe, healthy and entertained with smart connected technology.' }}</div>
        <div class="ft-cat__chips">
          <span>📍 GPS Trackers</span>
          <span>🤖 Auto Feeders</span>
        </div>
        <div class="ft-cat__count">{{ section.settings.pettech_count | default: '180+ Products' }}</div>
        <div class="ft-cat__link">
          Shop Pet Tech
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Wellbeing — wide bottom -->
      <a href="{{ section.settings.wellbeing_url | default: '/collections/wellbeing' }}" class="ft-cat-card ft-cat--wellbeing ft-cat--wide-bottom">
        <div class="ft-cat__glow"></div>
        <span class="ft-cat__emoji">{{ section.settings.wellbeing_emoji | default: '🧘' }}</span>
        <span class="ft-cat__badge">{{ section.settings.wellbeing_badge | default: 'Staff Pick' }}</span>
        <div class="ft-cat__name">{{ section.settings.wellbeing_title | default: 'Wellbeing & Health Tech' }}</div>
        <div class="ft-cat__desc">{{ section.settings.wellbeing_desc | default: 'Sleep better, stress less and live healthier with science-backed technology for your mind and body.' }}</div>
        <div class="ft-cat__chips">
          <span>😴 Sleep Tech</span>
          <span>🧠 Mental Wellness</span>
          <span>💆 Recovery</span>
          <span>🌿 Health Monitors</span>
        </div>
        <div class="ft-cat__count">{{ section.settings.wellbeing_count | default: '250+ Products' }}</div>
        <div class="ft-cat__link">
          Shop Wellbeing
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

    </div>
  </div>
</section>


<!-- ============================================================
     FUTURETECH — COMPLIANCE & POLICY SECTION
     ACCC-compliant AU policies: returns, shipping, privacy, consumer law
     Operator Playbook: reduce chargebacks, build trust, reduce disputes
============================================================ -->

<section class="ft-compliance section-pad" id="policies">
  <div class="ft-container">

    <div class="ft-section-head">
      <span class="ft-label">{{ section.settings.label | default: 'Compliance & Policies' }}</span>
      <h2 class="ft-section-title">{{ section.settings.heading | default: 'Our Policies & Consumer Rights' }}</h2>
      <p class="ft-section-sub">{{ section.settings.subheading | default: 'FutureTek operates in full compliance with Australian Consumer Law (ACL) and ACCC guidelines. Your rights are protected on every purchase.' }}</p>
    </div>

    <!-- ── POLICY TABS ── -->
    <div class="ft-comp-tabs">
      <button class="ft-comp-tab is-active" onclick="ftCompTab(this,'returns')">🔄 Returns & Refunds</button>
      <button class="ft-comp-tab" onclick="ftCompTab(this,'shipping')">🚚 Shipping Policy</button>
      <button class="ft-comp-tab" onclick="ftCompTab(this,'warranty')">🛡️ Warranty</button>
      <button class="ft-comp-tab" onclick="ftCompTab(this,'privacy')">🔒 Privacy</button>
      <button class="ft-comp-tab" onclick="ftCompTab(this,'acl')">⚖️ Consumer Law</button>
    </div>

    <!-- RETURNS TAB -->
    <div class="ft-comp-panel is-active" id="ft-comp-returns">
      <div class="ft-comp-panel__header">
        <div class="ft-comp-panel__icon">🔄</div>
        <div>
          <h3 class="ft-comp-panel__title">Returns & Refunds Policy</h3>
          <p class="ft-comp-panel__last-updated">Last updated: {{ section.settings.returns_updated | default: 'January 2025' }}</p>
        </div>
        <div class="ft-comp-panel__badge">ACCC Compliant</div>
      </div>
      <div class="ft-comp-policy-body">
        <div class="ft-comp-highlight ft-comp-highlight--green">
          <strong>30-Day Hassle-Free Returns</strong> — If you're not satisfied with your purchase, return it within 30 days of receipt for a full refund or exchange. No questions asked.
        </div>
        <h4>Eligibility</h4>
        <ul>
          <li>Item must be returned within <strong>30 days</strong> of delivery</li>
          <li>Item must be unused and in original packaging (for change-of-mind returns)</li>
          <li>Proof of purchase required (order number or invoice)</li>
          <li>Electronics must include all accessories and documentation</li>
        </ul>
        <h4>Faulty or Damaged Items</h4>
        <ul>
          <li>Photo or video evidence of fault required — email to <strong>{{ section.settings.support_email | default: 'support@futuretek.com.au' }}</strong></li>
          <li>We will organise a prepaid return label at no cost to you</li>
          <li>Choice of full refund, replacement, or store credit</li>
          <li>Under Australian Consumer Law, you are entitled to a remedy for major failures — this applies regardless of our stated policy</li>
        </ul>
        <h4>Process & Timeframes</h4>
        <div class="ft-comp-process-steps">
          <div class="ft-comp-step"><div class="ft-comp-step__num">1</div><div><div class="ft-comp-step__title">Contact Support</div><div class="ft-comp-step__desc">Email {{ section.settings.support_email | default: 'support@futuretek.com.au' }} with your order number and reason for return. Response within 24 hours.</div></div></div>
          <div class="ft-comp-step"><div class="ft-comp-step__num">2</div><div><div class="ft-comp-step__title">Return Authorisation</div><div class="ft-comp-step__desc">We'll issue a Return Authorisation number and shipping instructions within 1 business day.</div></div></div>
          <div class="ft-comp-step"><div class="ft-comp-step__num">3</div><div><div class="ft-comp-step__title">Ship the Item</div><div class="ft-comp-step__desc">Use the provided label (fault/damage) or your preferred carrier (change of mind). Keep your tracking number.</div></div></div>
          <div class="ft-comp-step"><div class="ft-comp-step__num">4</div><div><div class="ft-comp-step__title">Refund Processed</div><div class="ft-comp-step__desc">Once received and inspected, refund is processed within 3–5 business days to your original payment method.</div></div></div>
        </div>
        <div class="ft-comp-highlight ft-comp-highlight--yellow">
          <strong>Note:</strong> Refund timing may vary by bank/payment provider. AfterPay and Zip refunds follow their respective merchant refund processes.
        </div>
      </div>
    </div>

    <!-- SHIPPING TAB -->
    <div class="ft-comp-panel" id="ft-comp-shipping">
      <div class="ft-comp-panel__header">
        <div class="ft-comp-panel__icon">🚚</div>
        <div>
          <h3 class="ft-comp-panel__title">Shipping Policy</h3>
          <p class="ft-comp-panel__last-updated">Last updated: {{ section.settings.shipping_updated | default: 'January 2025' }}</p>
        </div>
        <div class="ft-comp-panel__badge ft-comp-panel__badge--blue">Truth-Safe Claims</div>
      </div>
      <div class="ft-comp-policy-body">
        <div class="ft-comp-highlight ft-comp-highlight--blue">
          <strong>Honest Shipping Disclosure:</strong> FutureTek operates on a dropshipping model. Products ship directly from our supplier network. All delivery estimates below reflect real supplier lead times to Australian addresses.
        </div>
        <div class="ft-comp-ship-grid">
          <div class="ft-comp-ship-card">
            <div class="ft-comp-ship-card__icon">📦</div>
            <div class="ft-comp-ship-card__title">Standard AU Delivery</div>
            <div class="ft-comp-ship-card__time">{{ section.settings.standard_ship | default: '7–14 business days' }}</div>
            <div class="ft-comp-ship-card__cost">Free on orders over $100 AUD</div>
            <div class="ft-comp-ship-card__note">Tracking included on all orders</div>
          </div>
          <div class="ft-comp-ship-card ft-comp-ship-card--featured">
            <div class="ft-comp-ship-card__icon">⚡</div>
            <div class="ft-comp-ship-card__title">Express AU Delivery</div>
            <div class="ft-comp-ship-card__time">{{ section.settings.express_ship | default: '4–7 business days' }}</div>
            <div class="ft-comp-ship-card__cost">$9.95 flat rate</div>
            <div class="ft-comp-ship-card__note">Priority processing + tracking</div>
          </div>
          <div class="ft-comp-ship-card">
            <div class="ft-comp-ship-card__icon">🌏</div>
            <div class="ft-comp-ship-card__title">International</div>
            <div class="ft-comp-ship-card__time">{{ section.settings.intl_ship | default: '14–21 business days' }}</div>
            <div class="ft-comp-ship-card__cost">Calculated at checkout</div>
            <div class="ft-comp-ship-card__note">Select countries only</div>
          </div>
        </div>
        <h4>Important Shipping Information</h4>
        <ul>
          <li>All delivery estimates are <strong>business days</strong> and begin from the date of supplier dispatch, not order date</li>
          <li>Dispatch typically occurs within <strong>1–3 business days</strong> of order confirmation</li>
          <li>Tracking numbers are emailed when the order is dispatched from our supplier</li>
          <li>Some products ship from multiple locations — you may receive separate parcels</li>
          <li>Delivery to remote or rural AU addresses may take additional time</li>
          <li>We do not guarantee delivery by any specific date — estimates are based on supplier and carrier data</li>
        </ul>
        <h4>Lost or Undelivered Orders</h4>
        <ul>
          <li>If your tracking shows "delivered" but you have not received your item, contact us within <strong>7 days</strong></li>
          <li>We will lodge an investigation with the carrier on your behalf</li>
          <li>If the carrier cannot resolve the issue within 10 business days, we will reship or refund in full</li>
        </ul>
      </div>
    </div>

    <!-- WARRANTY TAB -->
    <div class="ft-comp-panel" id="ft-comp-warranty">
      <div class="ft-comp-panel__header">
        <div class="ft-comp-panel__icon">🛡️</div>
        <div>
          <h3 class="ft-comp-panel__title">Warranty Policy</h3>
          <p class="ft-comp-panel__last-updated">Last updated: {{ section.settings.warranty_updated | default: 'January 2025' }}</p>
        </div>
        <div class="ft-comp-panel__badge ft-comp-panel__badge--green">2-Year Coverage</div>
      </div>
      <div class="ft-comp-policy-body">
        <div class="ft-comp-highlight ft-comp-highlight--green">
          <strong>2-Year Manufacturer Warranty</strong> on all FutureTek products, plus your full rights under Australian Consumer Law (which cannot be excluded, restricted or modified).
        </div>
        <h4>What Is Covered</h4>
        <ul>
          <li>Manufacturing defects and faults in materials or workmanship</li>
          <li>Hardware failures under normal use conditions</li>
          <li>Battery defects (capacity below 80% within the first 12 months)</li>
          <li>Display and connectivity issues not caused by physical damage</li>
        </ul>
        <h4>What Is Not Covered</h4>
        <ul>
          <li>Physical damage from drops, impacts, or liquid exposure (beyond stated IP rating)</li>
          <li>Damage from misuse, unauthorised modifications, or third-party repairs</li>
          <li>Normal wear and tear (scratches, cosmetic marks after use)</li>
          <li>Accessories including cables, cases, and ear tips (unless specified)</li>
        </ul>
        <h4>Claim Process</h4>
        <ul>
          <li>Email <strong>{{ section.settings.support_email | default: 'support@futuretek.com.au' }}</strong> with order number and fault description</li>
          <li>Include clear photos or video of the fault</li>
          <li>We'll assess and respond within 2 business days</li>
          <li>Approved claims: replacement unit shipped within 5 business days (subject to stock availability)</li>
        </ul>
      </div>
    </div>

    <!-- PRIVACY TAB -->
    <div class="ft-comp-panel" id="ft-comp-privacy">
      <div class="ft-comp-panel__header">
        <div class="ft-comp-panel__icon">🔒</div>
        <div>
          <h3 class="ft-comp-panel__title">Privacy Policy</h3>
          <p class="ft-comp-panel__last-updated">Last updated: {{ section.settings.privacy_updated | default: 'January 2025' }}</p>
        </div>
        <div class="ft-comp-panel__badge ft-comp-panel__badge--purple">Privacy Act Compliant</div>
      </div>
      <div class="ft-comp-policy-body">
        <div class="ft-comp-highlight ft-comp-highlight--purple">
          FutureTek complies with the <strong>Privacy Act 1988 (Cth)</strong> and the Australian Privacy Principles (APPs). We collect only what we need and protect your data.
        </div>
        <h4>What We Collect</h4>
        <ul>
          <li>Name, email address, delivery address (for order fulfilment)</li>
          <li>Payment information (processed securely via Shopify Payments — we never store card details)</li>
          <li>Browsing behaviour on our site (via cookies) for analytics and personalisation</li>
          <li>Marketing opt-in status for email/SMS communications</li>
        </ul>
        <h4>How We Use Your Data</h4>
        <ul>
          <li>Processing and fulfilling your orders</li>
          <li>Communicating about your order status and support</li>
          <li>Sending marketing communications (only if you have opted in)</li>
          <li>Improving our store experience through analytics</li>
        </ul>
        <h4>Your Rights</h4>
        <ul>
          <li>Access or correct your personal information at any time</li>
          <li>Unsubscribe from marketing emails (link in every email)</li>
          <li>Request deletion of your data (subject to legal retention requirements)</li>
          <li>Lodge a complaint with the Office of the Australian Information Commissioner (OAIC)</li>
        </ul>
        <h4>Third Parties</h4>
        <ul>
          <li>Shopify (platform) — <a href="https://www.shopify.com/legal/privacy" target="_blank" rel="noopener">privacy policy</a></li>
          <li>Klaviyo (email/SMS marketing) — only if you have opted in</li>
          <li>Supplier fulfilment partners — name and address only, for order dispatch</li>
          <li>We do not sell your data to any third party</li>
        </ul>
      </div>
    </div>

    <!-- ACL TAB -->
    <div class="ft-comp-panel" id="ft-comp-acl">
      <div class="ft-comp-panel__header">
        <div class="ft-comp-panel__icon">⚖️</div>
        <div>
          <h3 class="ft-comp-panel__title">Australian Consumer Law Rights</h3>
          <p class="ft-comp-panel__last-updated">As required under the Competition and Consumer Act 2010 (Cth)</p>
        </div>
        <div class="ft-comp-panel__badge ft-comp-panel__badge--orange">Statutory Rights</div>
      </div>
      <div class="ft-comp-policy-body">
        <div class="ft-comp-highlight ft-comp-highlight--orange">
          <strong>Your statutory consumer guarantees cannot be excluded or limited by our policies.</strong> The following rights apply to all purchases from FutureTek, regardless of any other terms.
        </div>
        <div class="ft-comp-acl-grid">
          <div class="ft-comp-acl-card">
            <div class="ft-comp-acl-card__icon">✅</div>
            <div class="ft-comp-acl-card__title">Acceptable Quality</div>
            <div class="ft-comp-acl-card__desc">Products must be safe, durable, free from defects, and acceptable in appearance for their intended purpose.</div>
          </div>
          <div class="ft-comp-acl-card">
            <div class="ft-comp-acl-card__icon">🎯</div>
            <div class="ft-comp-acl-card__title">Fit for Purpose</div>
            <div class="ft-comp-acl-card__desc">Goods must perform as described and be suitable for any specific purpose you communicated to us before purchase.</div>
          </div>
          <div class="ft-comp-acl-card">
            <div class="ft-comp-acl-card__icon">📋</div>
            <div class="ft-comp-acl-card__title">Match Description</div>
            <div class="ft-comp-acl-card__desc">Products must correspond to any description, sample or demonstration provided in our listings.</div>
          </div>
          <div class="ft-comp-acl-card">
            <div class="ft-comp-acl-card__icon">🔧</div>
            <div class="ft-comp-acl-card__title">Major Failure Remedy</div>
            <div class="ft-comp-acl-card__desc">For a major failure, you can choose a refund, replacement or repair. You are also entitled to compensation for consequential loss.</div>
          </div>
        </div>
        <h4>Remedies Available</h4>
        <ul>
          <li><strong>Minor failures:</strong> We will repair, replace or refund within a reasonable time</li>
          <li><strong>Major failures:</strong> You choose the remedy — full refund, replacement of equal value, or repair</li>
          <li><strong>Consequential loss:</strong> You may be entitled to compensation for losses that flow from a major failure</li>
        </ul>
        <div class="ft-comp-highlight ft-comp-highlight--blue">
          For more information, visit the <a href="https://www.accc.gov.au/consumers/consumer-rights-guarantees" target="_blank" rel="noopener">ACCC Consumer Rights page</a> or call the ACCC on <strong>1300 302 502</strong>.
        </div>
      </div>
    </div>

    <!-- Contact CTA -->
    <div class="ft-comp-contact">
      <div class="ft-comp-contact__icon">💬</div>
      <div>
        <div class="ft-comp-contact__title">Questions about any of our policies?</div>
        <div class="ft-comp-contact__sub">Our AU support team responds within 24 hours — Monday to Friday, 9am–5pm AEST.</div>
      </div>
      <div class="ft-comp-contact__actions">
        <a href="mailto:{{ section.settings.support_email | default: 'support@futuretek.com.au' }}" class="ft-btn ft-btn--primary">📧 Email Support</a>
        <a href="/pages/contact" class="ft-btn ft-btn--outline">Contact Form</a>
      </div>
    </div>

  </div>
</section>

<style>
/* ── Tabs ── */
.ft-comp-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:32px; }
.ft-comp-tab { padding:10px 18px; border-radius:10px; background:rgba(255,255,255,.04); border:1px solid var(--ft-border); color:var(--ft-muted); font-size:.82rem; font-weight:700; cursor:pointer; transition:.2s; white-space:nowrap; }
.ft-comp-tab.is-active, .ft-comp-tab:hover { background:rgba(0,240,255,.08); border-color:rgba(0,240,255,.2); color:var(--ft-cyan); }

/* ── Panels ── */
.ft-comp-panel { display:none; background:var(--ft-surface); border:1px solid var(--ft-border); border-radius:20px; padding:36px; margin-bottom:28px; }
.ft-comp-panel.is-active { display:block; }
.ft-comp-panel__header { display:flex; align-items:flex-start; gap:20px; margin-bottom:28px; padding-bottom:24px; border-bottom:1px solid var(--ft-border); flex-wrap:wrap; }
.ft-comp-panel__icon { font-size:2.4rem; flex-shrink:0; }
.ft-comp-panel__title { font-size:1.2rem; font-weight:900; color:#fff; margin-bottom:4px; }
.ft-comp-panel__last-updated { font-size:.78rem; color:var(--ft-muted); }
.ft-comp-panel__badge { margin-left:auto; padding:6px 14px; border-radius:50px; font-size:.72rem; font-weight:900; letter-spacing:.5px; background:rgba(52,211,153,.1); color:#34d399; border:1px solid rgba(52,211,153,.2); white-space:nowrap; align-self:flex-start; }
.ft-comp-panel__badge--blue { background:rgba(0,240,255,.1); color:var(--ft-cyan); border-color:rgba(0,240,255,.2); }
.ft-comp-panel__badge--green { background:rgba(52,211,153,.1); color:#34d399; border-color:rgba(52,211,153,.2); }
.ft-comp-panel__badge--purple { background:rgba(123,47,255,.1); color:var(--ft-purple); border-color:rgba(123,47,255,.2); }
.ft-comp-panel__badge--orange { background:rgba(255,107,53,.1); color:var(--ft-orange); border-color:rgba(255,107,53,.2); }

/* ── Policy Body ── */
.ft-comp-policy-body h4 { font-size:.9rem; font-weight:800; color:#fff; margin:22px 0 12px; text-transform:uppercase; letter-spacing:.5px; font-size:.8rem; }
.ft-comp-policy-body ul { list-style:none; padding:0; display:flex; flex-direction:column; gap:9px; margin-bottom:16px; }
.ft-comp-policy-body ul li { padding-left:20px; position:relative; font-size:.87rem; color:var(--ft-muted); line-height:1.65; }
.ft-comp-policy-body ul li::before { content:'›'; position:absolute; left:0; color:var(--ft-cyan); font-weight:900; }
.ft-comp-policy-body ul li strong { color:var(--ft-text); }
.ft-comp-policy-body a { color:var(--ft-cyan); text-decoration:none; }
.ft-comp-policy-body a:hover { text-decoration:underline; }

/* ── Highlights ── */
.ft-comp-highlight { padding:16px 20px; border-radius:12px; font-size:.88rem; line-height:1.7; margin-bottom:20px; }
.ft-comp-highlight--green { background:rgba(52,211,153,.06); border:1px solid rgba(52,211,153,.15); color:var(--ft-text); }
.ft-comp-highlight--yellow { background:rgba(255,193,7,.06); border:1px solid rgba(255,193,7,.15); color:var(--ft-text); }
.ft-comp-highlight--blue { background:rgba(0,240,255,.05); border:1px solid rgba(0,240,255,.12); color:var(--ft-text); }
.ft-comp-highlight--orange { background:rgba(255,107,53,.05); border:1px solid rgba(255,107,53,.15); color:var(--ft-text); }
.ft-comp-highlight--purple { background:rgba(123,47,255,.05); border:1px solid rgba(123,47,255,.15); color:var(--ft-text); }
.ft-comp-highlight strong { color:#fff; }

/* ── Process Steps ── */
.ft-comp-process-steps { display:flex; flex-direction:column; gap:12px; margin:16px 0; }
.ft-comp-step { display:flex; gap:14px; align-items:flex-start; }
.ft-comp-step__num { width:32px; height:32px; border-radius:50%; background:rgba(0,240,255,.12); color:var(--ft-cyan); font-weight:900; font-size:.85rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
.ft-comp-step__title { font-size:.88rem; font-weight:800; color:#fff; margin-bottom:3px; }
.ft-comp-step__desc { font-size:.82rem; color:var(--ft-muted); line-height:1.6; }

/* ── Ship Cards ── */
.ft-comp-ship-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin:20px 0; }
.ft-comp-ship-card { background:rgba(255,255,255,.03); border:1px solid var(--ft-border); border-radius:12px; padding:20px; text-align:center; }
.ft-comp-ship-card--featured { border-color:rgba(0,240,255,.25); background:rgba(0,240,255,.04); }
.ft-comp-ship-card__icon { font-size:1.8rem; margin-bottom:10px; }
.ft-comp-ship-card__title { font-size:.88rem; font-weight:800; color:#fff; margin-bottom:6px; }
.ft-comp-ship-card__time { font-size:1.05rem; font-weight:900; color:var(--ft-cyan); margin-bottom:5px; }
.ft-comp-ship-card__cost { font-size:.78rem; color:#34d399; font-weight:700; margin-bottom:4px; }
.ft-comp-ship-card__note { font-size:.72rem; color:var(--ft-muted); }

/* ── ACL Grid ── */
.ft-comp-acl-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin:20px 0; }
.ft-comp-acl-card { background:rgba(255,255,255,.03); border:1px solid var(--ft-border); border-radius:12px; padding:18px; }
.ft-comp-acl-card__icon { font-size:1.5rem; margin-bottom:9px; }
.ft-comp-acl-card__title { font-size:.85rem; font-weight:800; color:#fff; margin-bottom:7px; }
.ft-comp-acl-card__desc { font-size:.78rem; color:var(--ft-muted); line-height:1.6; }

/* ── Contact ── */
.ft-comp-contact { display:flex; align-items:center; gap:20px; background:linear-gradient(135deg,rgba(0,240,255,.06),rgba(123,47,255,.06)); border:1px solid rgba(0,240,255,.15); border-radius:18px; padding:28px 32px; flex-wrap:wrap; }
.ft-comp-contact__icon { font-size:2.2rem; flex-shrink:0; }
.ft-comp-contact__title { font-size:1rem; font-weight:800; color:#fff; margin-bottom:4px; }
.ft-comp-contact__sub { font-size:.84rem; color:var(--ft-muted); }
.ft-comp-contact__actions { display:flex; gap:10px; margin-left:auto; flex-wrap:wrap; }

@media(max-width:900px) {
  .ft-comp-ship-grid { grid-template-columns:1fr; }
  .ft-comp-acl-grid { grid-template-columns:1fr 1fr; }
  .ft-comp-contact { flex-direction:column; text-align:center; }
  .ft-comp-contact__actions { margin-left:0; }
}
@media(max-width:600px) {
  .ft-comp-acl-grid { grid-template-columns:1fr; }
  .ft-comp-panel { padding:20px; }
}
</style>

<script>
function ftCompTab(btn, panelId) {
  document.querySelectorAll('.ft-comp-tab').forEach(t => t.classList.remove('is-active'));
  document.querySelectorAll('.ft-comp-panel').forEach(p => p.classList.remove('is-active'));
  btn.classList.add('is-active');
  document.getElementById('ft-comp-' + panelId).classList.add('is-active');
}
</script>

{% schema %}
{
  "name": "FutureTek Compliance",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "Compliance & Policies" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Policies & Consumer Rights" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "FutureTek operates in full compliance with Australian Consumer Law (ACL) and ACCC guidelines. Your rights are protected on every purchase." },
    { "type": "text", "id": "support_email", "label": "Support Email", "default": "support@futuretek.com.au" },
    { "type": "text", "id": "returns_updated", "label": "Returns Policy Last Updated", "default": "January 2025" },
    { "type": "text", "id": "shipping_updated", "label": "Shipping Policy Last Updated", "default": "January 2025" },
    { "type": "text", "id": "warranty_updated", "label": "Warranty Policy Last Updated", "default": "January 2025" },
    { "type": "text", "id": "privacy_updated", "label": "Privacy Policy Last Updated", "default": "January 2025" },
    { "type": "text", "id": "standard_ship", "label": "Standard Delivery Window", "default": "7–14 business days" },
    { "type": "text", "id": "express_ship", "label": "Express Delivery Window", "default": "4–7 business days" },
    { "type": "text", "id": "intl_ship", "label": "International Delivery Window", "default": "14–21 business days" }
  ],
  "presets": [{ "name": "FutureTek Compliance Policies" }]
}
{% endschema %}
